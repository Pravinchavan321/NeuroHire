# ===== Runtime =====
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
API_BASE_URL=http://localhost:3000/api
VITE_API_URL=/api

# ===== Auth =====
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ===== PostgreSQL =====
DATABASE_URL=postgresql://admin:YOUR_PASSWORD_HERE@postgres:5432/neurohire
PG_HOST=postgres
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
PG_DB=neurohire

# ===== MongoDB =====
MONGODB_URI=mongodb://mongo:27017/neurohire
MONGO_URI=mongodb://mongo:27017/neurohire

# ===== ChromaDB =====
CHROMA_URL=http://chromadb:8000
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== AI Service / Gemini =====
AI_SERVICE_URL=http://ai-service:8000
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# ===== Email Notifications =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=NeuroHire Recruitment

# ===== Stripe =====
STRIPE_DISABLED=true
ENABLE_STRIPE=false
STRIPE_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ===== Lever OAuth =====
LEVER_CLIENT_ID=YOUR_LEVER_CLIENT_ID_HERE
LEVER_CLIENT_SECRET=YOUR_LEVER_CLIENT_SECRET_HERE
LEVER_REDIRECT_URI=http://localhost:3000/integrations/lever/callback
